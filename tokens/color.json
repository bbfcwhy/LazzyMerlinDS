{
  "$schema": "https://schemas.tokens-studio.com/latest/tokens-schema.json",
  "color": {
    "wood": {
      "$description": "Brand Core 8 色 wood palette（§2.1）。所有其他色都從這裡 reference 出來，不做新 hex。",
      "parchment":       { "$value": "#F5EFE4", "$type": "color", "$description": "Light surface · 奶油紙底" },
      "tan":             { "$value": "#DECCA7", "$type": "color", "$description": "Light surface muted / Dark ink muted" },
      "stone":           { "$value": "#967459", "$type": "color", "$description": "中性 muted accent · 兩 mode 共用" },
      "espresso":        { "$value": "#4E3029", "$type": "color", "$description": "Light ink muted / Dark surface muted" },
      "midnight-petrol": { "$value": "#0F1C26", "$type": "color", "$description": "Dark surface · Light ink · 品牌藍錨" },
      "primary-deep":    { "$value": "#334D5C", "$type": "color", "$description": "Brand 強調 · 兩 mode 共用 · dark mode 不當文字（對比不足）" },
      "primary":         { "$value": "#46647C", "$type": "color", "$description": "主 CTA / 連結色 · light primary = dark primary-soft" },
      "mid-petrol":      { "$value": "#5E7A8D", "$type": "color", "$description": "Light primary-soft = dark primary（兩 mode 互換）" }
    },
    "earth": {
      "$description": "Status Extension（§2.2）· 大地色系，跟 wood palette 同 saturation 量級。Status-only 不擴 brand core。",
      "terracotta": { "$value": "#9E5949", "$type": "color", "$description": "Error / destructive · Terracotta 陶土紅 · 跨 mode 同 hex (v0.2.0-rc.4 起收斂)" },
      "sage":       { "$value": "#596751", "$type": "color", "$description": "Success · Sage / Moss 苔蘚綠 · 跨 mode 同 hex · ⚠️ dark surface 上對比 ~2.7:1 邊緣不過 AA Large、僅適合 status icon / chip / dot 小面積" },
      "ochre":      { "$value": "#CB9B52", "$type": "color", "$description": "Warning · Burnt Ochre 赭石黃 · 跨 mode 同 hex · ⚠️ light surface 上對比 ~2.2:1 不過 AA、僅適合 status icon / chip 小面積、不作大 button fill" }
    },
    "light": {
      "$description": "Light mode role tokens · 所有 light mode CSS 用這層",
      "bg":            { "$value": "{color.wood.parchment}",       "$type": "color" },
      "bg-raised":     { "$value": "{color.wood.parchment}",       "$type": "color", "$description": "卡片底色（同 surface，靠 shadow 區分）" },
      "bg-muted":      { "$value": "{color.wood.tan}",             "$type": "color" },
      "ink":           { "$value": "{color.wood.midnight-petrol}", "$type": "color" },
      "ink-muted":     { "$value": "{color.wood.espresso}",        "$type": "color" },
      "ink-on-brand":  { "$value": "{color.wood.parchment}",       "$type": "color", "$description": "彩色底文字（不翻轉）· §15.5.4 全 component 通用 · v0.2.0-rc.3 起" },
      "primary":       { "$value": "{color.wood.primary}",         "$type": "color" },
      "primary-soft":  { "$value": "{color.wood.mid-petrol}",      "$type": "color" },
      "primary-deep":  { "$value": "{color.wood.primary-deep}",    "$type": "color" },
      "stone":         { "$value": "{color.wood.stone}",           "$type": "color" },
      "info":          { "$value": "{color.wood.primary}",         "$type": "color" },
      "success":       { "$value": "{color.earth.sage}",       "$type": "color" },
      "warning":       { "$value": "{color.earth.ochre}",      "$type": "color" },
      "error":         { "$value": "{color.earth.terracotta}", "$type": "color" },
      "destructive":   { "$value": "{color.earth.terracotta}", "$type": "color" }
    },
    "dark": {
      "$description": "Dark mode role tokens · primary ↔ primary-soft 互換、ink ↔ bg 互換 · ink-on-brand + earth tone 不翻轉",
      "bg":            { "$value": "{color.wood.midnight-petrol}", "$type": "color" },
      "bg-raised":     { "$value": "{color.wood.midnight-petrol}", "$type": "color" },
      "bg-muted":      { "$value": "{color.wood.espresso}",        "$type": "color" },
      "ink":           { "$value": "{color.wood.parchment}",       "$type": "color" },
      "ink-muted":     { "$value": "{color.wood.tan}",             "$type": "color" },
      "ink-on-brand":  { "$value": "{color.wood.parchment}",       "$type": "color", "$description": "彩色底文字（不翻轉、跟 light mode 同 hex）· §15.5.4" },
      "primary":       { "$value": "{color.wood.mid-petrol}",      "$type": "color", "$description": "= light primary-soft（互換）" },
      "primary-soft":  { "$value": "{color.wood.primary}",         "$type": "color", "$description": "= light primary（互換）" },
      "primary-deep":  { "$value": "{color.wood.primary-deep}",    "$type": "color" },
      "stone":         { "$value": "{color.wood.stone}",           "$type": "color" },
      "info":          { "$value": "{color.wood.mid-petrol}",      "$type": "color" },
      "success":       { "$value": "{color.earth.sage}",       "$type": "color", "$description": "Earth tone 跨 mode 同 hex (v0.2.0-rc.4 起)" },
      "warning":       { "$value": "{color.earth.ochre}",      "$type": "color" },
      "error":         { "$value": "{color.earth.terracotta}", "$type": "color" },
      "destructive":   { "$value": "{color.earth.terracotta}", "$type": "color" }
    },
    "transparent": {
      "$description": "rgba 透明度層（hairline / border / focus ring 等）",
      "border-light":     { "$value": "rgba(15, 28, 38, 0.10)",   "$type": "color" },
      "border-dark":      { "$value": "rgba(245, 239, 228, 0.08)", "$type": "color" },
      "hairline-light":   { "$value": "rgba(150, 116, 89, 0.30)",  "$type": "color" },
      "hairline-dark":    { "$value": "rgba(94, 122, 141, 0.30)",  "$type": "color" }
    }
  }
}
