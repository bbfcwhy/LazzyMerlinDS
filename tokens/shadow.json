{
  "$schema": "https://schemas.tokens-studio.com/latest/tokens-schema.json",
  "shadow": {
    "$description": "材質系統（§5）· 三層 register：Tactile / Hybrid / Soft Inset。完整 box-shadow 多層列表見 DESIGN.md §5.4。本檔僅列 token alias，完整 CSS 見 preview/components-preview.html。",
    "soft": {
      "$description": "Soft Neumorphic（§5.6）· 給 input / switch / slider 等控制元件的觸感層",
      "sm-light": {
        "$value": "6px 6px 12px rgba(33, 23, 21, 0.08), -6px -6px 12px rgba(255, 255, 255, 0.75)",
        "$type": "shadow"
      },
      "sm-dark": {
        "$value": "6px 6px 12px rgba(0, 0, 0, 0.45), -6px -6px 12px rgba(94, 122, 141, 0.06)",
        "$type": "shadow"
      },
      "md-light": {
        "$value": "10px 10px 20px rgba(33, 23, 21, 0.10), -10px -10px 20px rgba(255, 255, 255, 0.85)",
        "$type": "shadow"
      },
      "md-dark": {
        "$value": "10px 10px 20px rgba(0, 0, 0, 0.50), -10px -10px 20px rgba(94, 122, 141, 0.08)",
        "$type": "shadow"
      },
      "inset-light": {
        "$value": "inset 4px 4px 8px rgba(33, 23, 21, 0.08), inset -4px -4px 8px rgba(255, 255, 255, 0.75)",
        "$type": "shadow"
      },
      "inset-dark": {
        "$value": "inset 4px 4px 8px rgba(0, 0, 0, 0.35), inset -4px -4px 8px rgba(94, 122, 141, 0.06)",
        "$type": "shadow"
      }
    },
    "tactile-raised": {
      "$description": "Tactile Raised（§5.4.1）· v0.2.0 起跨平台共通配方：對角 LinearGradient + 單層上亮下暗 stroke + 2 層 drop shadow + PNG noise tile + text shadow + continuous radius。SwiftUI 等價見 §7.2.9 tactileRaised() ViewModifier。本 token 僅 box-shadow 部分（gradient / noise / text-shadow / radius 不在此檔），完整 CSS pattern 見 preview/components-preview.html。",
      "button-light": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.30), inset 0 -1px 0 rgba(0, 0, 0, 0.20), 0 2px 4px rgba(15, 28, 38, 0.15), 0 6px 12px rgba(15, 28, 38, 0.10)",
        "$type": "shadow"
      },
      "button-dark": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.15), inset 0 -1px 0 rgba(0, 0, 0, 0.40), 0 2px 6px rgba(0, 0, 0, 0.25), 0 8px 16px rgba(0, 0, 0, 0.20)",
        "$type": "shadow"
      },
      "card-light": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.50), inset 0 -1px 0 rgba(15, 28, 38, 0.10), 0 2px 4px rgba(15, 28, 38, 0.10), 0 4px 8px rgba(15, 28, 38, 0.06)",
        "$type": "shadow"
      },
      "card-dark": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.10), inset 0 -1px 0 rgba(0, 0, 0, 0.30), 0 2px 6px rgba(0, 0, 0, 0.20), 0 4px 10px rgba(0, 0, 0, 0.15)",
        "$type": "shadow"
      },
      "chip-light": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.30), inset 0 -1px 0 rgba(15, 28, 38, 0.18), 0 1px 2px rgba(15, 28, 38, 0.12), 0 2px 5px rgba(15, 28, 38, 0.08)",
        "$type": "shadow"
      },
      "chip-dark": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.10), inset 0 -1px 0 rgba(0, 0, 0, 0.35), 0 1px 2px rgba(0, 0, 0, 0.30), 0 2px 5px rgba(0, 0, 0, 0.25)",
        "$type": "shadow"
      },
      "avatar-light": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.30), inset 0 -1px 0 rgba(0, 0, 0, 0.25), 0 2px 4px rgba(15, 28, 38, 0.18), 0 4px 10px rgba(15, 28, 38, 0.12)",
        "$type": "shadow"
      },
      "avatar-dark": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.15), inset 0 -1px 0 rgba(0, 0, 0, 0.40), 0 2px 4px rgba(0, 0, 0, 0.40), 0 4px 10px rgba(0, 0, 0, 0.30)",
        "$type": "shadow"
      },
      "badge-light": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.25), inset 0 -1px 0 rgba(0, 0, 0, 0.20), 0 1px 2px rgba(15, 28, 38, 0.15)",
        "$type": "shadow"
      },
      "badge-dark": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.12), inset 0 -1px 0 rgba(0, 0, 0, 0.35), 0 1px 2px rgba(0, 0, 0, 0.40)",
        "$type": "shadow"
      }
    },
    "noise-overlay": {
      "$description": "Tactile noise overlay（§5.4 共通六件配方 #4）· v0.2.0 起改用 assets/tactile-noise.png（256×256 RGBA stitchable PNG，從 SVG turbulence baseFrequency=1.6 numOctaves=4 seed=5 stitchTiles=stitch render），跨平台共用同一份 asset。Light + Dark 統一 soft-light blend mode。",
      "blend-mode":    { "$value": "soft-light",                  "$type": "string" },
      "tile-path":     { "$value": "assets/tactile-noise.png",    "$type": "string" },
      "tile-size":     { "$value": "256px 256px",                 "$type": "string" },
      "opacity-light": { "$value": 0.08,                          "$type": "number" },
      "opacity-dark":  { "$value": 0.10,                          "$type": "number" }
    }
  }
}
