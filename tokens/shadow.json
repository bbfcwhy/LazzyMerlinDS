      "badge-dark": {
        "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.18), inset 0 -1px 0 rgba(0, 0, 0, 0.40), inset 0 0 0 1px rgba(0, 0, 0, 0.20), 1px 1px 2px rgba(0, 0, 0, 0.50), 2px 3px 5px rgba(0, 0, 0, 0.55)",
